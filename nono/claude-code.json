{
  "extends": "claude-code",
  "meta": {
    "name": "sdlc-claude",
    "description": "Claude Code sandbox for AI SDLC workflow"
  },
  "workdir": {
    "access": "readwrite"
  },
  "filesystem": {
    "read": [
      "/usr",
      "/lib",
      "/lib64",
      "/etc/ssl",
      "/etc/pki",
      "/etc/resolv.conf",
      "/etc/hosts",
      "/tmp"
    ],
    "write": [
      "/tmp"
    ],
    "deny": [
      "~/.ssh",
      "~/.aws",
      "~/.config/gh",
      "~/.gnupg",
      "~/.netrc",
      "~/.kube/config",
      "~/.docker/config.json"
    ]
  }
}

{
  "extends": "claude-code",
  "meta": {
    "name": "sdlc-claude",
    "description": "Claude Code sandbox for AI SDLC workflow"
  },
  "workdir": {
    "access": "readwrite"
  },
  "filesystem": {
    "read": [
      "/usr",
      "/lib",
      "/lib64",
      "/etc/ssl",
      "/etc/pki",
      "/etc/resolv.conf",
      "/etc/hosts",
      "/tmp",
      "$HOME/.config/gcloud"
    ],
    "write": [
      "/tmp"
    ]
  },
  "network": {
    "allow_domain": [
      "aiplatform.googleapis.com",
      "us-east5-aiplatform.googleapis.com",
      "oauth2.googleapis.com",
      "accounts.google.com",
      "www.googleapis.com"
    ]
  }
}
